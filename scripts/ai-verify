#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="full"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      MODE="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

case "$MODE" in
  full | ci-static | ci-data-core | ci-data-app-catalog | ci-data-app-sessions | ci-mock | ci-live-mvp | ci-live-owner | nightly-live-mvp) ;;
  *)
    echo "Unsupported verification mode: $MODE" >&2
    exit 2
    ;;
esac

cd "$ROOT"

VERIFY_SHA="$(git rev-parse HEAD)"
VERIFY_CLEAN=0
if [[ -z "$(git status --porcelain=v1)" ]]; then
  VERIFY_CLEAN=1
fi

VERIFY_CONFIG_SNAPSHOT="$(mktemp -d "${TMPDIR:-/tmp}/gyeop-ai-verify.XXXXXX")"
cp -p "$ROOT/next-env.d.ts" "$VERIFY_CONFIG_SNAPSHOT/next-env.d.ts"
cp -p "$ROOT/tsconfig.json" "$VERIFY_CONFIG_SNAPSHOT/tsconfig.json"

restore_generated_config() {
  cp -p "$VERIFY_CONFIG_SNAPSHOT/next-env.d.ts" "$ROOT/next-env.d.ts"
  cp -p "$VERIFY_CONFIG_SNAPSHOT/tsconfig.json" "$ROOT/tsconfig.json"
}

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required. Run: corepack enable && pnpm install --frozen-lockfile" >&2
  exit 1
fi

if [[ ! -d "$ROOT/node_modules" ]]; then
  echo "Dependencies are missing. Run: pnpm install --frozen-lockfile" >&2
  exit 1
fi

if [[ "$MODE" != "ci-mock" ]] &&
  { ! command -v docker >/dev/null 2>&1 || ! docker info >/dev/null 2>&1; }; then
  echo "A running Docker daemon is required for local Supabase verification." >&2
  exit 1
fi

SUPABASE_STARTED_BY_VERIFY=0
cleanup() {
  restore_generated_config
  rm -rf -- "$VERIFY_CONFIG_SNAPSHOT"
  if [[ "$SUPABASE_STARTED_BY_VERIFY" == "1" ]]; then
    pnpm exec supabase stop --no-backup >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

start_supabase() {
  if ! pnpm exec supabase status --output json >/dev/null 2>&1; then
    SUPABASE_STARTED_BY_VERIFY=1
  fi
  if ! pnpm supabase:start >/dev/null; then
    sleep 5
    if ! pnpm supabase:start >/dev/null; then
      echo "Local Supabase failed to start." >&2
      exit 1
    fi
  fi
  "$ROOT/scripts/wait-for-supabase-db"
}

restart_supabase() {
  pnpm supabase:stop >/dev/null
  SUPABASE_STARTED_BY_VERIFY=1
  start_supabase
}

reset_supabase_for_app() {
  pnpm supabase:reset || { sleep 5; pnpm supabase:reset; }
  "$ROOT/scripts/wait-for-supabase-db"
  node "$ROOT/scripts/wait-for-supabase-data-api.mjs"
}

VERIFY_BASE_REF="${GYEOP_VERIFY_BASE_REF:-origin/main}"

run_static_verification() {
  python3 "$ROOT/scripts/verify_project.py"
  node --check "$ROOT/scripts/task-harness.mjs"
  TASK_HARNESS_PATHS=(
    scripts/ai-verify
    scripts/verify-path-changes
    scripts/task-harness
    scripts/task-harness.mjs
    scripts/task-harness.test.mjs
  )
  if [[ "$("$ROOT/scripts/verify-path-changes" "$VERIFY_BASE_REF" "${TASK_HARNESS_PATHS[@]}")" == "skip" ]]; then
    echo "Task harness regression tests skipped: no harness changes."
  else
    node --test "$ROOT/scripts/task-harness.test.mjs"
  fi
  sh -n "$ROOT/scripts/task-harness"
  sh -n "$ROOT/scripts/verify-path-changes"
  sh -n "$ROOT/scripts/install-codex-skills"
  sh -n "$ROOT/ops/http-boundary/haproxy-origin-wrapper"
  sh -n "$ROOT/ops/render-entrypoint.sh"
  sh -n "$ROOT/ops/http-boundary/gyeop-loopback-firewall-restore"
  sh -n "$ROOT/ops/http-boundary/gyeop-loopback-firewall-probe"
  sh -n "$ROOT/tests/integration/http-boundary-host.test.sh"
  sh -n "$ROOT/tests/integration/render-deploy.test.sh"
  sh -n "$ROOT/tests/integration/visitor-assignment-upgrade.test.sh"
  sh -n "$ROOT/tests/integration/eligibility-cutover-upgrade.test.sh"
  bash -n "$ROOT/scripts/wait-for-supabase-db"
  node --check "$ROOT/scripts/wait-for-supabase-data-api.mjs"
  node --check "$ROOT/scripts/verify-zero-cost-mvp.mjs"
  bash -n "$ROOT/tests/integration/supabase-readiness.test.sh"
  "$ROOT/tests/integration/supabase-readiness.test.sh"

  VALIDATOR="${CODEX_HOME:-$HOME/.codex}/skills/.system/skill-creator/scripts/quick_validate.py"
  if [[ -f "$VALIDATOR" ]]; then
    if python3 -c 'import yaml' >/dev/null 2>&1; then
      SKILL_VALIDATOR=(python3)
    elif command -v uv >/dev/null 2>&1; then
      SKILL_VALIDATOR=(uv run --quiet --with pyyaml python)
    else
      echo "Skill validation requires PyYAML or uv." >&2
      exit 1
    fi

    for skill in "$ROOT"/.codex/skills/*; do
      "${SKILL_VALIDATOR[@]}" "$VALIDATOR" "$skill"
    done
  else
    echo "External skill validator unavailable; repository frontmatter checks passed."
  fi

  if rg -n "TODO|TBD" "$ROOT/.codex/skills" --glob 'SKILL.md'; then
    echo "Unresolved skill placeholders found." >&2
    exit 1
  fi

  pnpm format:check
  pnpm lint
  pnpm typecheck
  pnpm test
  pnpm test:secrets
  node scripts/verify-zero-cost-mvp.mjs
  node scripts/verify-data-access.mjs
  node scripts/verify-http-boundary.mjs
  node scripts/verify-pack-catalog.mjs
  node scripts/verify-owner-flow.mjs
  node scripts/verify-owner-profile.mjs
  node scripts/verify-private-one-to-one.mjs
  node scripts/verify-share-links.mjs
  node scripts/verify-visitor-response.mjs
  node --test tests/integration/http-boundary.test.mjs
  tests/integration/http-boundary-host.test.sh
}

run_data_core_verification() {
  start_supabase
  UPGRADE_TEST_PATHS=(
    scripts/ai-verify
    scripts/verify-path-changes
    package.json
    pnpm-lock.yaml
    supabase/config.toml
    supabase/seed.sql
    supabase/migrations
    tests/integration/visitor-assignment-upgrade.test.sh
    tests/integration/eligibility-cutover-upgrade.test.sh
  )
  if [[ "$("$ROOT/scripts/verify-path-changes" "$VERIFY_BASE_REF" "${UPGRADE_TEST_PATHS[@]}")" == "skip" ]]; then
    echo "Upgrade regression tests skipped: no migration-path changes."
  else
    tests/integration/visitor-assignment-upgrade.test.sh
    tests/integration/eligibility-cutover-upgrade.test.sh
  fi
  pnpm supabase:reset || { sleep 5; pnpm supabase:reset; }
  "$ROOT/scripts/wait-for-supabase-db"
  pnpm test:db
  pnpm supabase:lint
  node scripts/verify-supabase-types.mjs
}

run_data_app_catalog_integrations() {
  node --test tests/integration/data-access.test.mjs
  node --test tests/integration/pack-catalog.test.mjs
  node --test tests/integration/pack-publication-concurrency.test.mjs
}

run_data_app_session_integrations() {
  node --test tests/integration/owner-play-session.test.mjs
  node --test tests/integration/owner-profile-session.test.mjs
  node --test tests/integration/owner-play-concurrency.test.mjs
  node --test tests/integration/share-link-concurrency.test.mjs
  node --test tests/integration/visitor-response-concurrency.test.mjs
  node --test tests/integration/visitor-withdrawal-concurrency.test.mjs
}

run_data_app_runtime_verification() {
  env -u NEXT_PUBLIC_SUPABASE_URL -u SUPABASE_SECRET_KEY pnpm build
  node --test tests/integration/pack-runtime.test.mjs
}

run_mock_verification() {
  env -u NEXT_PUBLIC_GA_MEASUREMENT_ID GYEOP_E2E_PORT=3110 pnpm test:e2e --project=mobile-chromium
  pnpm test:e2e:analytics
}

case "$MODE" in
  ci-live-mvp)
    start_supabase
    pnpm test:e2e:mvp:pr:run
    echo "GYEOP CI live MVP verification passed."
    exit 0
    ;;
  nightly-live-mvp)
    start_supabase
    pnpm test:e2e:mvp:nightly:run
    echo "GYEOP nightly live MVP verification passed."
    exit 0
    ;;
  ci-live-owner)
    start_supabase
    pnpm test:e2e:owner:run
    echo "GYEOP CI live owner verification passed."
    exit 0
    ;;
  ci-static)
    run_static_verification
    echo "GYEOP CI static verification passed."
    exit 0
    ;;
  ci-data-core)
    run_data_core_verification
    echo "GYEOP CI data core verification passed."
    exit 0
    ;;
  ci-data-app-catalog)
    start_supabase
    reset_supabase_for_app
    run_data_app_catalog_integrations
    run_data_app_runtime_verification
    echo "GYEOP CI data app catalog verification passed."
    exit 0
    ;;
  ci-data-app-sessions)
    start_supabase
    reset_supabase_for_app
    run_data_app_session_integrations
    echo "GYEOP CI data app sessions verification passed."
    exit 0
    ;;
  ci-mock)
    run_mock_verification
    echo "GYEOP CI mock E2E verification passed."
    exit 0
    ;;
  full)
    run_static_verification
    run_data_core_verification
    run_data_app_catalog_integrations
    run_data_app_session_integrations
    run_data_app_runtime_verification
    restart_supabase
    pnpm test:e2e:mvp:run
    pnpm test:e2e:owner
    run_mock_verification
    ;;
esac

restore_generated_config

if [[ "$VERIFY_CLEAN" == "1" ]] &&
  [[ "$(git rev-parse HEAD)" == "$VERIFY_SHA" ]] &&
  [[ -z "$(git status --porcelain=v1)" ]]; then
  VERIFY_MARKER_DIR="$(git rev-parse --path-format=absolute --git-common-dir)/gyeop-full-verify"
  mkdir -p "$VERIFY_MARKER_DIR"
  touch "$VERIFY_MARKER_DIR/$VERIFY_SHA"
else
  echo "Full verification passed, but its SHA was not cached because the checkout changed or was dirty."
fi

echo "GYEOP full verification passed."
