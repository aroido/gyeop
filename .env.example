GYEOP_GITHUB_REPO=aroido/gyeop
GYEOP_GITHUB_OWNER=aroido
GYEOP_GITHUB_PROJECT_NUMBER=5
GYEOP_MAIN_BRANCH=main
# GYEOP_WORKTREE_ROOT=/absolute/path/to/gyeop-worktrees

# Local Supabase public values. Generate .env.local with `supabase status -o env`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public GA4 web stream ID. Only exact G-[A-Z0-9]+ values enable consent UI.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Server-only Supabase secret. Data access is restricted to lib/db/internal-rpc.ts.
SUPABASE_SECRET_KEY=

# Public server origin. Production must be an HTTPS origin on port 443.
APP_URL=

# Server-only 32-byte base64url secrets. ORIGIN_PROXY_SECRET accepts current[.secondary].
ORIGIN_PROXY_SECRET=
RATE_LIMIT_SECRET=

# Server-only versioned keys. Keep values in .env.local or the server secret file only.
ACCOUNT_DELETE_REAUTH_KEYRING=
ACCOUNT_DELETE_REAUTH_ACTIVE_VERSION=
