GYEOP_GITHUB_REPO=owner/gyeop
GYEOP_GITHUB_OWNER=owner
GYEOP_GITHUB_PROJECT_NUMBER=1
GYEOP_MAIN_BRANCH=main
# GYEOP_WORKTREE_ROOT=/absolute/path/to/gyeop-worktrees

# Local Supabase public values. Generate .env.local with `supabase status -o env`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only versioned keys. Keep values in .env.local or the server secret file only.
ACCOUNT_DELETE_REAUTH_KEYRING=
ACCOUNT_DELETE_REAUTH_ACTIVE_VERSION=
